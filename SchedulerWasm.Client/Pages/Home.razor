@page "/"
@rendermode InteractiveWebAssembly
@inject DataService Data
@inject NavigationManager Nav

<PageTitle>لوحة التحكم</PageTitle>

@if (!loaded)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    var conflicts = Data.DetectConflicts();
    var todayLessons = Data.Lessons.Where(l => l.Type == LessonType.Weekly && l.DayOfWeek == DateTime.Today.DayOfWeek).ToList();
    var weeklyCount = Data.Lessons.Count(l => l.Type == LessonType.Weekly);

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-speedometer2 text-primary"></i> لوحة التحكم</h3>
        <span class="text-muted">@DateTime.Now.ToString("yyyy-MM-dd dddd")</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card stat-card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                    <div><h3 class="mb-0">@Data.Students.Count</h3><small class="text-muted">الطلاب</small></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card stat-card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-calendar-week"></i></div>
                    <div><h3 class="mb-0">@weeklyCount</h3><small class="text-muted">الحصص الأسبوعية</small></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card stat-card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-info bg-opacity-10 text-info"><i class="bi bi-journal-check"></i></div>
                    <div><h3 class="mb-0">@todayLessons.Count</h3><small class="text-muted">حصص اليوم</small></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card stat-card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon @(conflicts.Count > 0 ? "bg-danger bg-opacity-10 text-danger" : "bg-success bg-opacity-10 text-success")">
                        <i class="bi @(conflicts.Count > 0 ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
                    </div>
                    <div><h3 class="mb-0">@conflicts.Count</h3><small class="text-muted">تعارضات</small></div>
                </div>
            </div>
        </div>
    </div>

    @if (conflicts.Any())
    {
        <div class="alert alert-danger conflict-alert d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
            <div><strong>تنبيه:</strong> توجد @conflicts.Count تعارضات! <a href="conflicts" class="alert-link">عرض التفاصيل</a></div>
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h5 class="mb-0"><i class="bi bi-journal-text text-primary"></i> حصص اليوم</h5></div>
                <div class="card-body">
                    @if (todayLessons.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light"><tr><th>المادة</th><th>الطالب</th><th>الوقت</th><th>المدة</th></tr></thead>
                                <tbody>
                                    @foreach (var l in todayLessons.OrderBy(l => l.StartTime))
                                    {
                                        <tr>
                                            <td><span class="badge bg-primary">@l.Subject</span></td>
                                            <td>@Data.GetStudentName(l.StudentId)</td>
                                            <td><i class="bi bi-clock"></i> @l.StartTime</td>
                                            <td>@l.DurationMinutes دقيقة</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4"><i class="bi bi-calendar-x fs-1"></i><p class="mt-2">لا توجد حصص اليوم</p></div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h5 class="mb-0"><i class="bi bi-lightning text-warning"></i> إجراءات سريعة</h5></div>
                <div class="card-body d-grid gap-2">
                    <a href="students/add" class="btn btn-outline-primary btn-lg text-start"><i class="bi bi-person-plus"></i> إضافة طالب</a>
                    <a href="lessons/add" class="btn btn-outline-success btn-lg text-start"><i class="bi bi-plus-circle"></i> إضافة حصة</a>
                    <a href="schedule" class="btn btn-outline-info btn-lg text-start"><i class="bi bi-table"></i> عرض الجدول</a>
                    <a href="conflicts" class="btn btn-outline-warning btn-lg text-start"><i class="bi bi-exclamation-triangle"></i> التعارضات</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loaded = false;
    protected override async Task OnInitializedAsync()
    {
        await Data.LoadAsync();
        loaded = true;
    }
}
