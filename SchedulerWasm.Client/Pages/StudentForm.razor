@page "/students/add"
@page "/students/edit/{Id:int}"
@rendermode InteractiveWebAssembly
@inject DataService Data
@inject NavigationManager Nav

<PageTitle>طالب</PageTitle>

<div class="mb-4">
    <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="students">الطلاب</a></li><li class="breadcrumb-item active">@(IsEdit ? "تعديل" : "إضافة")</li></ol></nav>
    <h3><i class="bi @(IsEdit ? "bi-pencil" : "bi-person-plus") text-primary"></i> @(IsEdit ? "تعديل الطالب" : "إضافة طالب جديد")</h3>
</div>

<div class="row"><div class="col-lg-6">
    <div class="card shadow-sm"><div class="card-body">
        <div class="mb-3"><label class="form-label fw-bold">اسم الطالب *</label><input class="form-control" @bind="model.Name" placeholder="أدخل اسم الطالب" /></div>
        <div class="mb-3"><label class="form-label fw-bold">رقم الهاتف</label><input class="form-control" @bind="model.Phone" placeholder="05XXXXXXXX" /></div>
        <div class="mb-3"><label class="form-label fw-bold">ملاحظات</label><textarea class="form-control" @bind="model.Notes" rows="3" placeholder="ملاحظات..."></textarea></div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save" disabled="@(model.Name == "")"><i class="bi bi-check-lg"></i> @(IsEdit ? "حفظ" : "إضافة")</button>
            <a href="students" class="btn btn-secondary">رجوع</a>
        </div>
    </div></div>
</div></div>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id.HasValue;
    private Student model = new();
    protected override void OnInitialized() { if (IsEdit) model = Data.GetStudent(Id!.Value) ?? new Student(); }
    private async Task Save() { if (IsEdit) await Data.UpdateStudent(model); else await Data.AddStudent(model); Nav.NavigateTo("/students"); }
}
